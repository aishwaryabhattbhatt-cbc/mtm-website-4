# Google Sheets CMS
# Required: Spreadsheet ID from URL https://docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEET_ID=

# Optional direct published CSV URLs by page.
# Use this when Google Sheets is published and you want to plug in exact tab/page feeds directly.
# Example: {"home":"https://docs.google.com/spreadsheets/d/e/.../pub?output=csv"}
GOOGLE_SHEET_CSV_URL_MAP_JSON={"home":""}

# JSON map: pageId -> tab gid
# Example: {"home":"0","about":"123456789"}
GOOGLE_SHEET_TAB_MAP_JSON={"home":"0"}

# Runtime refresh interval for near-live updates (milliseconds)
PUBLIC_CMS_REFRESH_MS=30000
