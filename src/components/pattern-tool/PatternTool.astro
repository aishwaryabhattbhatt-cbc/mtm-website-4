---
// Pattern Tool Component (isolated instance)
const base = import.meta.env.BASE_URL;
---

<section class="pattern-tool-layout">
  <div id="webgl-background-pattern-tool" class="pattern-tool-canvas"></div>
  <aside id="pattern-tool-gui" class="pattern-tool-gui"></aside>
</section>

<style>
  .pattern-tool-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 16px;
    width: 100%;
    min-height: 100vh;
    padding: 16px;
    box-sizing: border-box;
  }

  .pattern-tool-canvas {
    position: relative;
    min-height: calc(100vh - 32px);
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
  }

  .pattern-tool-gui {
    min-height: calc(100vh - 32px);
  }

  @media (max-width: 980px) {
    .pattern-tool-layout {
      grid-template-columns: 1fr;
    }

    .pattern-tool-gui {
      min-height: auto;
    }
  }
</style>
