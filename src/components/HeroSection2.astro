---
// src/components/HeroSection2.astro
import ResearchSection2 from "./ResearchSection2.astro"
---

<!-- Home Section 2: Hero with WebGL Noise Warp Background -->
<section class="hero-section home-section-2">
    <!-- WebGL Noise Warp Canvas (Three.js) -->
    <div id="webgl-background-10" class="webgl-background"></div>

    <!-- Grain Overlay for Texture -->
    <div class="grain-overlay-10 grain-overlay"></div>

    <!-- Top White Gradient Overlay -->
    <div class="hero10-top-gradient"></div>

    <!-- Bottom White Gradient Overlay -->
    <div class="hero10-bottom-gradient"></div>

    <!-- Top Gradient Settings GUI (Hidden by Default) -->
    <div class="hero10-gradient-gui" style="display:none;">
        <label style="display:block; margin-bottom:6px; color:#333; font-size:13px; font-weight:600;">Top Gradient Settings</label>
        <label style="font-size:12px; color:#444;">Height (% of viewport):
            <input type="range" min="5" max="30" value="30" id="gradientHeightSlider10" style="vertical-align:middle;">
            <span id="gradientHeightValue10">30</span>vh
        </label>
        <br>
        <label style="font-size:12px; color:#444;">Opacity (0-1):
            <input type="range" min="0" max="1" step="0.01" value="1" id="gradientOpacitySlider10" style="vertical-align:middle;">
            <span id="gradientOpacityValue10">1</span>
        </label>
        <br>
        <label style="font-size:12px; color:#444;">Intensity (fade):
            <input type="range" min="0.1" max="2" step="0.01" value="1" id="gradientIntensitySlider10" style="vertical-align:middle;">
            <span id="gradientIntensityValue10">1</span>
        </label>
    </div>

        <!-- Position GUI (Section 2 scoped) -->
        <div class="box-gui-panel is-collapsed" id="boxGuiPanel">
                <div class="box-gui-header" style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                        <strong class="box-gui-title" style="font-size:13px;">🎛️ Position GUI</strong>
                        <button id="boxGuiToggle" type="button" style="padding:2px 9px; font-size:16px; line-height:1.2; cursor:pointer; border:1px solid #ccc; border-radius:5px; background:#f5f5f5;">+</button>
                </div>
                <div id="guiBody" style="display:none;">
                        <div id="guiTabLabel" style="font-size:11px; color:#888; margin-bottom:4px;">Technology Trends</div>

                        <div id="guiTab0">
                                <label>
                                        Select Box:
                                        <select id="boxSelect">
                                                <option value="box1">Box 1 (Large)</option>
                                                <option value="box2">Box 2 (Large)</option>
                                                <option value="box3">Box 3 (Small)</option>
                                                <option value="box4">Box 4 (Small)</option>
                                                <option value="box5">Box 5 (XS)</option>
                                        </select>
                                </label>
                                <label>
                                        Left (px): <input id="boxLeft" type="range" min="0" max="900" step="1" />
                                        <span id="boxLeftValue">40px</span>
                                </label>
                                <label>
                                        Top (px): <input id="boxTop" type="range" min="0" max="600" step="1" />
                                        <span id="boxTopValue">60px</span>
                                </label>
                        </div>

                        <div id="guiTab1" style="display:none">
                                <label>
                                        Select Box:
                                        <select id="t1boxSelect">
                                                <option value="box1">Box 1 (Large)</option>
                                                <option value="box2">Box 2 (Large)</option>
                                                <option value="box3">Box 3 (Small)</option>
                                                <option value="box4">Box 4 (Small)</option>
                                                <option value="box5">Box 5 (XS)</option>
                                        </select>
                                </label>
                                <label>
                                        Left (px): <input id="t1boxLeft" type="range" min="0" max="900" step="1" />
                                        <span id="t1boxLeftValue">199px</span>
                                </label>
                                <label>
                                        Top (px): <input id="t1boxTop" type="range" min="0" max="600" step="1" />
                                        <span id="t1boxTopValue">139px</span>
                                </label>
                        </div>

                        <div id="guiTab2" style="display:none">
                                <em style="font-size:11px; color:#999;">Grid layout — configure later</em>
                        </div>

                        <div style="display:flex; gap:6px; margin-top:8px;">
                                <button id="boxGuiCopy" type="button" style="flex:1; padding:5px 6px; font-size:11px; cursor:pointer; border:1px solid #ccc; border-radius:6px; background:#f0f7ff;">📋 Copy JSON</button>
                                <button id="boxGuiDownload" type="button" style="flex:1; padding:5px 6px; font-size:11px; cursor:pointer; border:1px solid #ccc; border-radius:6px; background:#f0fff4;">⬇️ Download</button>
                        </div>
                </div>
        </div>

    <ResearchSection2 />
</section>

<style>
    .home-section-2 {
        position: relative;
    }

    .home-section-2 .box-gui-panel {
        position: absolute;
        right: 0;
        bottom: 0;
        background: #fff;
        border: 1px solid #d9d9d9;
        border-radius: 10px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.15);
        padding: 16px 18px;
        z-index: 30;
        display: flex;
        flex-direction: column;
        gap: 12px;
        width: 240px;
        font-size: 13px;
    }

    .home-section-2 .box-gui-panel.is-collapsed {
        width: auto;
        padding: 6px;
        gap: 0;
        border-radius: 999px;
    }

    .home-section-2 .box-gui-panel.is-collapsed .box-gui-title {
        display: none;
    }

    .home-section-2 .box-gui-panel.is-collapsed .box-gui-header {
        justify-content: center;
    }

    .home-section-2 .box-gui-panel.is-collapsed #boxGuiToggle {
        width: 28px;
        height: 28px;
        padding: 0 !important;
        border-radius: 999px !important;
        font-size: 18px !important;
        line-height: 1 !important;
    }

    .home-section-2 .box-gui-panel label {
        display: flex;
        flex-direction: column;
        gap: 4px;
        font-size: 12px;
    }

    .home-section-2 .box-gui-panel select,
    .home-section-2 .box-gui-panel input[type='range'] {
        width: 100%;
        font-size: 13px;
    }
</style>
