---
// src/components/HomeHeroSection.astro
import type { CMSDictionary, Locale } from '../lib/cms/types';
import { t } from '../lib/i18n/t';

interface Props {
    locale: Locale;
    copy: CMSDictionary;
}

const { locale, copy } = Astro.props as Props;
const base = import.meta.env.BASE_URL;

const copyKeys = {
    title: 'hero_title',
    subtitle: 'hero_description',
    ctaPrimary: 'hero_cta_1',
    ctaSecondary: 'hero_cta_2',
};
---

<!-- Home Section 1: Hero with WebGL Noise Warp Background -->
<section class="hero-section home-section-1">
    <!-- WebGL Noise Warp Canvas (Three.js) -->
    <div id="webgl-background-11" class="webgl-background"></div>

    <!-- Grain Overlay for Texture -->
    <div class="grain-overlay-11 grain-overlay"></div>

    <!-- Hero Content and Collage -->
    <div class="hero-container">
        <div class="hero-content">
    
            <h1 class="hero-title" data-copy-key={copyKeys.title}>{t(copy, copyKeys.title, locale, 'The Standard for Media & Tech Insights')}</h1>
            <p class="hero-subtitle" data-copy-key={copyKeys.subtitle}>{t(copy, copyKeys.subtitle, locale, "Real data on how Canadians consume tech, content, and media. Built for leaders who don't guess.")}</p>
            <div class="hero-buttons">
                <button class="hero-btn hero-btn-primary" data-copy-key={copyKeys.ctaPrimary}>{t(copy, copyKeys.ctaPrimary, locale, 'REQUEST A DEMO')}</button>
                <button class="hero-btn hero-btn-secondary" data-copy-key={copyKeys.ctaSecondary}>{t(copy, copyKeys.ctaSecondary, locale, 'EXPLORE MORE')}</button>
            </div>
        </div>
        <div class="hero-image-collage">
            <img src={`${base}svg/1.svg`} alt="Collage Image 1" class="collage-image collage-image-1">
            <img src={`${base}svg/2.svg`} alt="Collage Image 2" class="collage-image collage-image-2">
            <img src={`${base}svg/3.svg`} alt="Collage Image 3" class="collage-image collage-image-3">
            <img src={`${base}svg/4.svg`} alt="Collage Image 4" class="collage-image collage-image-4">
            <img src={`${base}svg/5.svg`} alt="Collage Image 5" class="collage-image collage-image-5">
        </div>
    </div>

    <!-- Bottom White Gradient Overlay -->
    <div class="hero11-bottom-gradient"></div>
</section>
