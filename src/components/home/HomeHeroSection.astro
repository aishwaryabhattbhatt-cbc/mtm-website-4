---
// src/components/home/HomeHeroSection.astro
import type { CMSDictionary, Locale } from '../../lib/cms/types';
import { t } from '../../lib/i18n/t';
import Button from '../shared/Button.astro';
import collage1 from '../../assets/svg/1.svg';
import collage2 from '../../assets/svg/2.svg';
import collage3 from '../../assets/svg/3.svg';
import collage4 from '../../assets/svg/4.svg';
import collage5 from '../../assets/svg/5.svg';

interface Props {
    locale: Locale;
    copy: CMSDictionary;
}

const { locale, copy } = Astro.props as Props;

const copyKeys = {
    title: 'hero_title',
    subtitle: 'hero_description',
    ctaPrimary: 'hero_cta_1',
    ctaSecondary: 'hero_cta_2',
};
---

<!-- Home Section 1: Hero with WebGL Noise Warp Background -->
<section class="hero-section home-section-1">
    <!-- WebGL Noise Warp Canvas (Three.js) -->
    <div
        id="webgl-background-11"
        class="webgl-background"
        data-webgl-variant="home"
        aria-hidden="true"
    >
    </div>

    <!-- Grain Overlay for Texture -->
    <div class="grain-overlay-11 grain-overlay" aria-hidden="true"></div>

    <!-- Hero Content and Collage -->
    <div class="hero-container">
        <div class="hero-content">
            <h1 class="hero-title" data-copy-key={copyKeys.title}>
                {t(copy, copyKeys.title, locale, 'The Standard for Media & Tech Insights')}
            </h1>
            <p class="hero-subtitle text-body-p0" data-copy-key={copyKeys.subtitle}>
                {
                    t(
                        copy,
                        copyKeys.subtitle,
                        locale,
                        "Real data on how Canadians consume tech, content, and media. Built for leaders who don't guess."
                    )
                }
            </p>
            <div class="hero-buttons">
                <Button variant="primary" size="lg" data-copy-key={copyKeys.ctaPrimary}
                    >{t(copy, copyKeys.ctaPrimary, locale, 'REQUEST A DEMO')}</Button
                >
                <Button variant="scroll" size="lg" data-copy-key={copyKeys.ctaSecondary}
                    >{t(copy, copyKeys.ctaSecondary, locale, 'EXPLORE MORE')}</Button
                >
            </div>
        </div>
        <div class="hero-image-collage">
            <img
                src={collage1.src}
                alt=""
                class="collage-image collage-image-1"
                loading="lazy"
                decoding="async"
            />
            <img
                src={collage2.src}
                alt=""
                class="collage-image collage-image-2"
                loading="lazy"
                decoding="async"
            />
            <img
                src={collage3.src}
                alt=""
                class="collage-image collage-image-3"
                loading="lazy"
                decoding="async"
            />
            <img
                src={collage4.src}
                alt=""
                class="collage-image collage-image-4"
                loading="lazy"
                decoding="async"
            />
            <img
                src={collage5.src}
                alt=""
                class="collage-image collage-image-5"
                loading="lazy"
                decoding="async"
            />
        </div>
    </div>

    <!-- Bottom White Gradient Overlay -->
    <div class="hero11-bottom-gradient" aria-hidden="true"></div>
</section>

<style is:global>
    .hero-section.home-section-1 {
        position: relative;
        margin-bottom: 0 !important;
    }

    .hero11-gradient-gui {
        position: absolute;
        left: 20px;
        bottom: 20px;
        z-index: 30;
        background: rgba(255, 255, 255, 0.95);
        border-radius: var(--radius-s);
        box-shadow: var(--shadow-e2);
        padding: 14px 18px 10px 18px;
        min-width: 210px;
        max-width: 260px;
        user-select: none;
    }

    .hero11-bottom-gradient {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        width: 100vw;
        height: 10vh;
        pointer-events: none;
        z-index: 10;
        background: linear-gradient(to top, rgba(255, 255, 255, 1) 0%, rgba(255, 255, 255, 0) 100%);
    }

    .home-section-1 .hero-container {
        position: absolute;
        z-index: 20;
        top: 50%;
        transform: translateY(-50%);
        left: 0;
        right: 0;
        width: 100%;
        padding: 0 var(--content-margin-inline);
        display: flex;
        align-items: center;
        gap: auto;
        justify-content: space-between;
    }

    .home-section-1 .hero-content {
        max-width: min(43.75rem, calc(100% - 43.75rem));
        display: flex;
        flex-direction: column;
        align-self: flex-start;
        gap: var(--space-6);
    }

    .hero-image-collage {
        position: relative;
        width: 620px;
        height: 530px;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out forwards;
        overflow: visible;
        padding-top: 0 !important;
        margin-top: 0 !important;
    }

    .collage-image {
        position: absolute;
        object-fit: cover;
        opacity: 0;
        animation: fadeInUp forwards;
        transition:
            transform 0.3s ease-out,
            box-shadow 0.3s ease-out;
        border-radius: var(--radius-s);
    }

    .collage-image:hover {
        transform: scale(1.08);
        box-shadow: var(--shadow-card);
    }

    .collage-image-1 {
        width: 141px;
        height: 122px;
        left: 153px;
        top: 0;
        z-index: 5;
    }

    .collage-image-2 {
        width: 314px;
        height: 348px;
        left: 306px;
        top: 0;
        z-index: 5;
    }

    .collage-image-3 {
        width: 211px;
        height: 31px;
        left: 409px;
        top: 360px;
        z-index: 5;
    }

    .collage-image-4 {
        width: 158px;
        height: 170px;
        left: 239px;
        top: 355px;
        z-index: 10;
    }

    .collage-image-5 {
        width: 287px;
        height: 346px;
        left: 7px;
        top: 134px;
        z-index: 1;
    }

    .hero-title-word {
        display: inline-block;
        opacity: 0;
        transform: translateY(20px);
        animation: wordAppear 0.6s ease-out forwards;
    }

    .hero-subtitle {
        color: var(--text-primary);
        margin: 0;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out forwards;
    }

    .hero-buttons {
        display: flex;
        margin-top: var(--space-5);
        gap: var(--space-4);
        flex-wrap: wrap;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out forwards;
    }

    @keyframes wordAppear {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fadeInUp {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Proportional scale-down: 1555px → 1440px
       Both columns shrink at the same rate (ratio of available content widths: 1200÷1315 = 0.913)
       --hero-scale interpolates linearly between 1.0 and 0.913 across this range */
    @media (min-width: 1440px) and (max-width: 1554px) {
        .home-section-1 .hero-container {
            --hero-scale: calc(0.913 + (100vw - 1440px) / 1321px);
        }

        .home-section-1 .hero-content {
            /* reserve collage width + 5rem gap — text narrows instead of the gap collapsing */
            max-width: calc(100% - 38.75rem * var(--hero-scale) - 5rem);
            gap: calc(var(--space-6) * var(--hero-scale));
        }

        .hero-title {
            font-size: calc(var(--fs-hero) * var(--hero-scale));
        }

        .hero-subtitle {
            font-size: calc(var(--fs-body-xl) * var(--hero-scale));
        }

        /* zoom shrinks the collage AND its layout footprint — all absolute-positioned
           images inside scale correctly without any position recalculation */
        .hero-image-collage {
            zoom: var(--hero-scale);
            flex-shrink: 0;
        }
    }

    /* Proportional scale-down: 1439px → 1024px
       Continuous with the 1440–1554px range: scale = 0.913 at both shared boundaries */
    @media (min-width: 1024px) and (max-width: 1439px) {
        .home-section-1 .hero-container {
            --hero-scale: calc(0.7 + (100vw - 1024px) / 1949px);
        }

        .home-section-1 .hero-content {
            max-width: calc(100% - 38.75rem * var(--hero-scale) - 5rem);
            gap: calc(var(--space-6) * var(--hero-scale));
        }

        .hero-title {
            font-size: calc(var(--fs-hero) * var(--hero-scale));
        }

        .hero-subtitle {
            font-size: calc(var(--fs-body-xl) * var(--hero-scale));
        }

        .hero-image-collage {
            zoom: var(--hero-scale);
            flex-shrink: 0;
        }
    }

    @media (max-width: 1023px) {
        .home-section-1 .hero-container {
            flex-direction: column;
            justify-content: flex-start;
            align-items: flex-start;
            gap: var(--space-8);
            /* anchor to top of section instead of centering, then 5rem below navbar */
            top: 0;
            transform: none;
            padding-top: var(--space-12);
        }

        .home-section-1 .hero-content {
            /* container already provides horizontal padding — no double indent */
            padding: 0;
            max-width: 100%;
            width: 100%;
            text-align: center;
        }

        .hero-buttons {
            display: grid;
            grid-template-columns: max-content;
            justify-content: center;
            gap: var(--space-3);
        }

        .hero-buttons .btn-size-lg {
            padding: var(--space-4) var(--space-5);
            min-height: 2.75rem;
            text-align: center;
            justify-content: center;
        }

        .hero-image-collage {
            align-self: center;
            flex-shrink: 0;
        }
    }

    /* Scale collage to fit within viewport once it exceeds available width (<668px) */
    @media (max-width: 767px) {
        .hero-image-collage {
            zoom: min(1, calc((100vw - 48px) / 620px));
        }
    }

    /* ≤480px: design system drops html to 14px root — text tokens scale down automatically. */
    @media (max-width: 480px) {
        .hero-subtitle {
            font-size: var(--fs-a11y-floor);
        }
    }
</style>
