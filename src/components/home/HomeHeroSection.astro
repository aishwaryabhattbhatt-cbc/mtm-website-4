---
// src/components/home/HomeHeroSection.astro
import type { CMSDictionary, Locale } from '../../lib/cms/types';
import { t } from '../../lib/i18n/t';
import Button from '../shared/Button.astro';

interface Props {
    locale: Locale;
    copy: CMSDictionary;
}

const { locale, copy } = Astro.props as Props;
const base = import.meta.env.BASE_URL;

const copyKeys = {
    title: 'hero_title',
    subtitle: 'hero_description',
    ctaPrimary: 'hero_cta_1',
    ctaSecondary: 'hero_cta_2',
};
---

<!-- Home Section 1: Hero with WebGL Noise Warp Background -->
<section class="hero-section home-section-1">
    <!-- WebGL Noise Warp Canvas (Three.js) -->
    <div id="webgl-background-11" class="webgl-background" data-webgl-variant="home"></div>

    <!-- Grain Overlay for Texture -->
    <div class="grain-overlay-11 grain-overlay"></div>

    <!-- Hero Content and Collage -->
    <div class="hero-container">
        <div class="hero-content">
    
            <h1 class="hero-title" data-copy-key={copyKeys.title}>{t(copy, copyKeys.title, locale, 'The Standard for Media & Tech Insights')}</h1>
            <p class="hero-subtitle" data-copy-key={copyKeys.subtitle}>{t(copy, copyKeys.subtitle, locale, "Real data on how Canadians consume tech, content, and media. Built for leaders who don't guess.")}</p>
            <div class="hero-buttons">
                <Button variant="primary" size="lg" data-copy-key={copyKeys.ctaPrimary}>{t(copy, copyKeys.ctaPrimary, locale, 'REQUEST A DEMO')}</Button>
                <Button variant="secondary" size="lg" data-copy-key={copyKeys.ctaSecondary}>{t(copy, copyKeys.ctaSecondary, locale, 'EXPLORE MORE')}</Button>
            </div>
        </div>
        <div class="hero-image-collage">
            <img src={`${base}svg/1.svg`} alt="Collage Image 1" class="collage-image collage-image-1">
            <img src={`${base}svg/2.svg`} alt="Collage Image 2" class="collage-image collage-image-2">
            <img src={`${base}svg/3.svg`} alt="Collage Image 3" class="collage-image collage-image-3">
            <img src={`${base}svg/4.svg`} alt="Collage Image 4" class="collage-image collage-image-4">
            <img src={`${base}svg/5.svg`} alt="Collage Image 5" class="collage-image collage-image-5">
        </div>
    </div>

    <!-- Bottom White Gradient Overlay -->
    <div class="hero11-bottom-gradient"></div>
</section>

<style is:global>
    .hero-section.home-section-1 {
        position: relative;
        margin-bottom: 0 !important;
    }

    .hero11-gradient-gui {
        position: absolute;
        left: 20px;
        bottom: 20px;
        z-index: 30;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.10);
        padding: 14px 18px 10px 18px;
        font-family: system-ui, sans-serif;
        font-size: 13px;
        min-width: 210px;
        max-width: 260px;
        user-select: none;
    }

    .hero11-bottom-gradient {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        width: 100vw;
        height: 10vh;
        pointer-events: none;
        z-index: 10;
        background: linear-gradient(to top, rgba(255, 255, 255, 1) 0%, rgba(255, 255, 255, 0) 100%);
    }

    .home-section-1 .hero-container {
        position: absolute;
        z-index: 20;
        top: 50%;
        transform: translateY(-50%);
        left: 0;
        right: 0;
        width: 100%;
        padding: 0 var(--content-margin-inline);
        display: flex;
        align-items: center;
        gap: auto;
        justify-content: space-between;
    }

    .home-section-1 .hero-content {
        max-width: 700px;
        display: flex;
        flex-direction: column;
        align-self: flex-start;
        gap: 24px;
    }

    .hero-image-collage {
        position: relative;
        width: 620px;
        height: 530px;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out forwards;
        overflow: visible;
        padding-top: 0 !important;
        margin-top: 0 !important;
    }

    .collage-image {
        position: absolute;
        object-fit: cover;
        opacity: 0;
        animation: fadeInUp forwards;
        transition: transform 0.3s ease-out, box-shadow 0.3s ease-out;
        border-radius: 8px;
    }

    .collage-image:hover {
        transform: scale(1.08);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
    }

    .collage-image-1 {
        width: 141px;
        height: 122px;
        left: 153px;
        top: 0;
        z-index: 5;
    }

    .collage-image-2 {
        width: 314px;
        height: 348px;
        left: 306px;
        top: 0;
        z-index: 5;
    }

    .collage-image-3 {
        width: 211px;
        height: 31px;
        left: 409px;
        top: 360px;
        z-index: 5;
    }

    .collage-image-4 {
        width: 158px;
        height: 170px;
        left: 239px;
        top: 355px;
        z-index: 10;
    }

    .collage-image-5 {
        width: 287px;
        height: 346px;
        left: 7px;
        top: 134px;
        z-index: 1;
    }

    .hero-title {
        font-family: var(--font-family-heading);
        font-size: 84px;
        font-weight: 600;
        line-height: 1.1;
        color: var(--color-black);
        margin: 0;
        letter-spacing: -0.04em;
    }

    .hero-title-word {
        display: inline-block;
        opacity: 0;
        transform: translateY(20px);
        animation: wordAppear 0.6s ease-out forwards;
    }

    .hero-subtitle {
        font-family: var(--font-family-base);
        font-size: 28px;
        font-weight: 500;
        line-height: 1.4;
        color: var(--color-black);
        margin: 0;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out forwards;
    }

    .hero-buttons {
        display: flex;
        margin-top: 20px;
        gap: 16px;
        flex-wrap: wrap;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out forwards;
    }

    @keyframes wordAppear {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fadeInUp {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 1023px) {
        .home-section-1 .hero-content {
            padding: 0 var(--content-margin-inline);
            padding-top: 40px;
            max-width: 100%;
        }

        .hero-title {
            font-size: 48px;
        }

        .hero-subtitle {
            font-size: 18px;
        }

        .hero-buttons {
            gap: 12px;
        }

        .hero-buttons .btn-size-lg {
            font-size: 16px;
            padding: 10px 18px;
        }
    }
</style>
