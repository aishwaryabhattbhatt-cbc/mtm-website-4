---
// src/components/home/HomeIntroductionSection.astro
import ResearchTabsSection from './ResearchTabsSection.astro';
import type { CMSDictionary, Locale } from '../../lib/cms/types';

interface Props {
    locale: Locale;
    copy: CMSDictionary;
}

const { locale, copy } = Astro.props as Props;
---

<!-- Home Section 2: Hero with WebGL Noise Warp Background -->
<section class="hero-section home-section-2">
    <!-- WebGL Noise Warp Canvas (Three.js) -->
    <div id="webgl-background-10" class="webgl-background"></div>

    <!-- Grain Overlay for Texture -->
    <div class="grain-overlay-10 grain-overlay"></div>

    <!-- Top White Gradient Overlay -->
    <div class="hero10-top-gradient"></div>

    <!-- Bottom White Gradient Overlay -->
    <div class="hero10-bottom-gradient"></div>

    <ResearchTabsSection locale={locale} copy={copy} />
</section>

<style is:global>
    .hero10-top-gradient {
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        width: 100vw;
        height: 30vh;
        pointer-events: none;
        z-index: 10;
        background: linear-gradient(to bottom, rgba(255, 255, 255, 1) 0%, rgba(255, 255, 255, 0) 100%);
    }

    .hero10-bottom-gradient {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        width: 100vw;
        height: 10vh;
        pointer-events: none;
        z-index: 10;
        background: linear-gradient(to top, rgba(255, 255, 255, 1) 0%, rgba(255, 255, 255, 0) 100%);
    }

    .home-section-2 {
        position: relative;
        margin-top: 0 !important;
        height: 100vh;
    }

    .home-section-2 .box-gui-panel {
        position: absolute;
        right: 0;
        bottom: 0;
        background: #fff;
        border: 1px solid #d9d9d9;
        border-radius: 10px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.15);
        padding: 16px 18px;
        z-index: 30;
        display: flex;
        flex-direction: column;
        gap: 12px;
        width: 240px;
        font-size: 13px;
    }

    .home-section-2 .box-gui-panel.is-collapsed {
        width: auto;
        padding: 6px;
        gap: 0;
        border-radius: 999px;
    }

    .home-section-2 .box-gui-panel.is-collapsed .box-gui-title {
        display: none;
    }

    .home-section-2 .box-gui-panel.is-collapsed .box-gui-header {
        justify-content: center;
    }

    .home-section-2 .box-gui-panel.is-collapsed #boxGuiToggle {
        width: 28px;
        height: 28px;
        padding: 0 !important;
        border-radius: 999px !important;
        font-size: 18px !important;
        line-height: 1 !important;
    }

    .home-section-2 .box-gui-panel label {
        display: flex;
        flex-direction: column;
        gap: 4px;
        font-size: 12px;
    }

    .home-section-2 .box-gui-panel select,
    .home-section-2 .box-gui-panel input[type='range'] {
        width: 100%;
        font-size: 13px;
    }

    @media (max-width: 1023px) {
        .hero-section.home-section-2 {
            height: 80vh;
        }
    }
</style>
