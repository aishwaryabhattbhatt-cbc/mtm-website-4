---
type ButtonVariant = 'primary' | 'secondary' | 'scroll';
type ButtonSize = 'md' | 'lg';

interface Props {
    variant?: ButtonVariant;
    size?: ButtonSize;
    href?: string;
    type?: 'button' | 'submit' | 'reset';
    class?: string;
}

const {
    variant = 'primary',
    size = 'md',
    href,
    type = 'button',
    class: className = '',
    ...attrs
} = Astro.props as Props & Record<string, unknown>;

const base = import.meta.env.BASE_URL;
const scrollIconSrc = `${base}svg/icon-chevron%201.svg`;

const variantClass =
    variant === 'secondary'
        ? 'btn-outline'
        : variant === 'scroll'
            ? 'btn-scroll'
            : 'btn-primary';

const isScroll = variant === 'scroll';

const classes = ['btn', variantClass, `btn-size-${size}`, className]
    .filter(Boolean)
    .join(' ');
---

{href ? (
    <a href={href} class={classes} {...attrs}>
        {isScroll ? (
            <>
                <span class="btn-scroll-label"><slot /></span>
                <span class="btn-scroll-icon" aria-hidden="true">
                    <img src={scrollIconSrc} alt="" loading="lazy" decoding="async" />
                </span>
            </>
        ) : (
            <slot />
        )}
    </a>
) : (
    <button type={type} class={classes} {...attrs}>
        {isScroll ? (
            <>
                <span class="btn-scroll-label"><slot /></span>
                <span class="btn-scroll-icon" aria-hidden="true">
                    <img src={scrollIconSrc} alt="" loading="lazy" decoding="async" />
                </span>
            </>
        ) : (
            <slot />
        )}
    </button>
)}

<style is:global>
    .btn {
        padding: var(--space-3) var(--space-5);
        font-size: var(--fs-button-small);
        font-weight: var(--fw-medium);
        line-height: var(--lh-tight);
        border-radius: var(--radius-s);
        font-family: var(--font-button);
        text-transform: uppercase;
        letter-spacing: var(--ls-button);
        text-decoration: none;
        cursor: pointer;
        border: var(--stroke-2) solid transparent;
        transition: all 0.3s ease;
        display: inline-block;
        white-space: nowrap;
    }

    .btn-outline {
        background-color: var(--surface-white);
        color: var(--text-primary);
        border: var(--stroke-1) solid var(--border-secondary);
    }

    .btn-outline:hover {
        background-color: var(--neutral-grey-4);
        transform: translateY(-2px);
        box-shadow: var(--shadow-e2);
    }

    .btn-primary {
        background-color: var(--neutral-black);
        color: var(--text-white);
        border: none;
    }

    .btn-primary:hover {
        background-color: var(--neutral-grey-1);
        transform: translateY(-2px);
        box-shadow: var(--shadow-e2);
    }

    .btn-scroll {
        border: none;
        background: transparent;
        color: var(--text-primary);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-3);
        font-size: var(--fs-button-regular);
        font-weight: var(--fw-medium);
    }

    .btn-scroll:hover {
        transform: translateY(-2px);
        background: rgba(0, 0, 0, 0.03);
    }

    .btn-scroll-label {
        display: inline-block;
    }

    .btn-scroll-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 16.04px;
        height: 16.04px;
        line-height: 1;
    }

    .btn-scroll-icon img {
        width: 100%;
        height: 100%;
        display: block;
    }

    .btn-size-md {
        font-size: var(--fs-button-small);
        letter-spacing: var(--ls-button-small);
        padding: var(--space-3) var(--space-5);
    }

    .btn-size-lg {
        font-size: var(--fs-button-regular);
        padding: var(--space-3) var(--space-5);
    }
</style>
