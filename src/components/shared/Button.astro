---
type ButtonVariant = 'primary' | 'secondary' | 'scroll' | 'tertiary';
type ButtonSize = 'md' | 'lg';

interface Props {
    variant?: ButtonVariant;
    size?: ButtonSize;
    href?: string;
    type?: 'button' | 'submit' | 'reset';
    class?: string;
    tabindex?: number | string;
    'aria-label'?: string;
}

const {
    variant = 'primary',
    size = 'md',
    href,
    type = 'button',
    class: className = '',
    ...attrs
} = Astro.props as Props & Record<string, unknown>;

import scrollIconAsset from '../../assets/svg/icon-chevron.svg';
const scrollIconSrc = scrollIconAsset.src;

const variantClass =
    variant === 'secondary'
        ? 'btn-outline'
        : variant === 'scroll'
          ? 'btn-scroll'
          : variant === 'tertiary'
            ? 'btn-tertiary'
            : 'btn-primary';

const isScroll = variant === 'scroll';
const isTertiary = variant === 'tertiary';

const textClass = size === 'lg' ? 'text-button-regular' : 'text-button-small';

const classes = ['btn', variantClass, `btn-size-${size}`, textClass, className]
    .filter(Boolean)
    .join(' ');
---

{
    href ? (
        <a href={href} class={classes} {...attrs}>
            {isScroll ? (
                <>
                    <span class="btn-scroll-label">
                        <slot />
                    </span>
                    <span class="btn-scroll-icon" aria-hidden="true">
                        <img src={scrollIconSrc} alt="" loading="lazy" decoding="async" />
                    </span>
                </>
            ) : isTertiary ? (
                <>
                    <span class="btn-tertiary-label">
                        <slot />
                    </span>
                    <span class="btn-tertiary-icon" aria-hidden="true">
                        <img src={scrollIconSrc} alt="" loading="lazy" decoding="async" />
                    </span>
                </>
            ) : (
                <slot />
            )}
        </a>
    ) : (
        <button type={type} class={classes} {...attrs}>
            {isScroll ? (
                <>
                    <span class="btn-scroll-label">
                        <slot />
                    </span>
                    <span class="btn-scroll-icon" aria-hidden="true">
                        <img src={scrollIconSrc} alt="" loading="lazy" decoding="async" />
                    </span>
                </>
            ) : isTertiary ? (
                <>
                    <span class="btn-tertiary-label">
                        <slot />
                    </span>
                    <span class="btn-tertiary-icon" aria-hidden="true">
                        <img src={scrollIconSrc} alt="" loading="lazy" decoding="async" />
                    </span>
                </>
            ) : (
                <slot />
            )}
        </button>
    )
}

<style is:global>
    .btn {
        padding: var(--space-3) var(--space-5);
        border-radius: var(--radius-s);
        text-decoration: none;
        cursor: pointer;
        border: var(--stroke-2) solid transparent;
        transition: all 0.3s ease;
        display: inline-block;
        white-space: nowrap;
    }

    .btn-outline {
        background-color: var(--surface-white);
        color: var(--text-primary);
        border: var(--stroke-1) solid var(--border-secondary);
    }

    .btn-outline:hover {
        background-color: var(--neutral-grey-4);
        transform: translateY(-2px);
        box-shadow: var(--shadow-e2);
    }

    .btn-primary {
        background-color: var(--neutral-black);
        color: var(--text-white);
        border: none;
    }

    .btn-primary:hover {
        background-color: var(--neutral-grey-1);
        transform: translateY(-2px);
        box-shadow: var(--shadow-e2);
    }

    .btn-scroll {
        border: none;
        background: transparent;
        color: var(--text-primary);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-3);
    }

    .btn-scroll:hover {
        transform: translateY(-2px);
    }

    .btn-scroll-label {
        display: inline-block;
    }

    .btn-scroll-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1rem;
        height: 1rem;
        line-height: var(--lh-tight);
    }

    .btn-scroll-icon img {
        width: 100%;
        height: 100%;
        display: block;
    }

    .btn-tertiary {
        border: none;
        background: transparent;
        color: var(--text-primary);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-3);
    }

    .btn-tertiary:hover {
        transform: translateY(-2px);
    }

    .btn-tertiary-label {
        display: inline-block;
    }

    .btn-tertiary-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1rem;
        height: 1rem;
        line-height: var(--lh-tight);
        transform: rotate(-90deg);
    }

    .btn-tertiary-icon img {
        width: 100%;
        height: 100%;
        display: block;
    }

    .btn-size-md {
        padding: var(--space-3) var(--space-5);
    }

    .btn-size-lg {
        padding: var(--space-3) var(--space-5);
    }

    .btn-scroll,
    .btn-tertiary {
        padding-left: 0;
        padding-right: 0;
    }
</style>
