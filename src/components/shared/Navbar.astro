---
// src/components/shared/Navbar.astro
import type { CMSDictionary, Locale } from '../../lib/cms/types';
import { t } from '../../lib/i18n/t';
import Button from './Button.astro';
import mtmLogo from '../../assets/svg/mtm-logo.svg';

interface Props {
    locale: Locale;
    copy: CMSDictionary;
    localeSwitchUrls?: Record<Locale, string>;
}

const { locale, copy, localeSwitchUrls } = Astro.props as Props;
const base = import.meta.env.BASE_URL;

const copyKeys = {
    products: 'home.nav.products',
    tools: 'home.nav.tools',
    solutions: 'home.nav.solutions',
    insights: 'home.nav.insights',
    signIn: 'home.nav.signIn',
    requestDemo: 'home.nav.requestDemo',
};

const frUrl = localeSwitchUrls?.fr ?? `${base}fr/`;
const enUrl = localeSwitchUrls?.en ?? `${base}en/`;
const homeUrl = `${base}${locale}/`;
const signInUrl = `${base}${locale}/sign-in/`;
const requestDemoUrl = `${base}${locale}/request-demo/`;
---

<nav class="navbar">
    <div class="navbar-container">
        <!-- MTM Logo -->
        <a class="navbar-logo" href={homeUrl} aria-label="MTM home">
            <img src={mtmLogo.src} alt="MTM - Media Technology Monitor" class="logo-image" />
        </a>

        <!-- Hamburger Menu for Mobile -->
        <button
            class="hamburger"
            id="hamburger"
            type="button"
            aria-label="Open navigation menu"
            aria-controls="navbar-menu"
            aria-expanded="false"
        >
            <span></span>
            <span></span>
            <span></span>
        </button>

        <!-- Navigation Menu Links -->
        <div class="navbar-menu" id="navbar-menu">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a
                        href={`${base}${locale}/products`}
                        class="nav-link text-button-small"
                        data-tooltip=""
                        data-copy-key={copyKeys.products}
                        >{t(copy, copyKeys.products, locale, 'PRODUCTS')}</a
                    >
                </li>
                <li class="nav-item">
                    <a
                        href={`${base}${locale}/tools`}
                        class="nav-link text-button-small"
                        data-tooltip=""
                        data-copy-key={copyKeys.tools}>{t(copy, copyKeys.tools, locale, 'TOOLS')}</a
                    >
                </li>
                <li class="nav-item">
                    <a
                        href={`${base}${locale}/solutions`}
                        class="nav-link text-button-small"
                        data-tooltip=""
                        data-copy-key={copyKeys.solutions}
                        >{t(copy, copyKeys.solutions, locale, 'SOLUTIONS')}</a
                    >
                </li>
                <li class="nav-item">
                    <a
                        href={`${base}${locale}/insights`}
                        class="nav-link text-button-small"
                        data-tooltip=""
                        data-copy-key={copyKeys.insights}
                        >{t(copy, copyKeys.insights, locale, 'INSIGHTS')}</a
                    >
                </li>
            </ul>

            <!-- Action Buttons and Language Selector -->
            <div class="navbar-actions">
                <!-- Language Selector (FR/EN) -->
                <div class="navbar-language">
                    <a
                        class={`lang-btn text-label-xs ${locale === 'fr' ? 'active' : ''}`}
                        data-lang="fr"
                        href={frUrl}
                        hreflang="fr"
                        lang="fr"
                        aria-current={locale === 'fr' ? 'page' : undefined}
                    >
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 14 14"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M7.00008 12.8333C6.20286 12.8333 5.44939 12.6802 4.73967 12.3739C4.02994 12.0677 3.41015 11.6496 2.88029 11.1198C2.35043 10.5899 1.93237 9.97013 1.62612 9.26041C1.31987 8.55068 1.16675 7.79721 1.16675 6.99999C1.16675 6.19305 1.31987 5.43714 1.62612 4.73228C1.93237 4.02742 2.35043 3.41006 2.88029 2.8802C3.41015 2.35034 4.02994 1.93228 4.73967 1.62603C5.44939 1.31978 6.20286 1.16666 7.00008 1.16666C7.80703 1.16666 8.56293 1.31978 9.26779 1.62603C9.97265 1.93228 10.59 2.35034 11.1199 2.8802C11.6497 3.41006 12.0678 4.02742 12.374 4.73228C12.6803 5.43714 12.8334 6.19305 12.8334 6.99999C12.8334 7.79721 12.6803 8.55068 12.374 9.26041C12.0678 9.97013 11.6497 10.5899 11.1199 11.1198C10.59 11.6496 9.97265 12.0677 9.26779 12.3739C8.56293 12.6802 7.80703 12.8333 7.00008 12.8333ZM7.00008 11.6375C7.25286 11.2875 7.47161 10.9229 7.65633 10.5437C7.84105 10.1646 7.99175 9.7611 8.10842 9.33332H5.89175C6.00842 9.7611 6.15911 10.1646 6.34383 10.5437C6.52855 10.9229 6.7473 11.2875 7.00008 11.6375ZM5.48342 11.4042C5.30841 11.0833 5.15529 10.7503 5.02404 10.4052C4.89279 10.0601 4.78342 9.70277 4.69591 9.33332H2.97508C3.25703 9.81944 3.60946 10.2424 4.03237 10.6021C4.45529 10.9618 4.93897 11.2292 5.48342 11.4042ZM8.51675 11.4042C9.06119 11.2292 9.54487 10.9618 9.96779 10.6021C10.3907 10.2424 10.7431 9.81944 11.0251 9.33332H9.30425C9.21675 9.70277 9.10737 10.0601 8.97612 10.4052C8.84487 10.7503 8.69175 11.0833 8.51675 11.4042ZM2.47925 8.16666H4.46258C4.43341 7.97221 4.41154 7.7802 4.39696 7.59062C4.38237 7.40103 4.37508 7.20416 4.37508 6.99999C4.37508 6.79582 4.38237 6.59895 4.39696 6.40937C4.41154 6.21978 4.43341 6.02777 4.46258 5.83332H2.47925C2.43064 6.02777 2.39418 6.21978 2.36987 6.40937C2.34557 6.59895 2.33341 6.79582 2.33341 6.99999C2.33341 7.20416 2.34557 7.40103 2.36987 7.59062C2.39418 7.7802 2.43064 7.97221 2.47925 8.16666ZM5.62925 8.16666H8.37092C8.40008 7.97221 8.42196 7.7802 8.43654 7.59062C8.45112 7.40103 8.45842 7.20416 8.45842 6.99999C8.45842 6.79582 8.45112 6.59895 8.43654 6.40937C8.42196 6.21978 8.40008 6.02777 8.37092 5.83332H5.62925C5.60008 6.02777 5.57821 6.21978 5.56362 6.40937C5.54904 6.59895 5.54175 6.79582 5.54175 6.99999C5.54175 7.20416 5.54904 7.40103 5.56362 7.59062C5.57821 7.7802 5.60008 7.97221 5.62925 8.16666ZM9.53758 8.16666H11.5209C11.5695 7.97221 11.606 7.7802 11.6303 7.59062C11.6546 7.40103 11.6667 7.20416 11.6667 6.99999C11.6667 6.79582 11.6546 6.59895 11.6303 6.40937C11.606 6.21978 11.5695 6.02777 11.5209 5.83332H9.53758C9.56675 6.02777 9.58862 6.21978 9.60321 6.40937C9.61779 6.59895 9.62508 6.79582 9.62508 6.99999C9.62508 7.20416 9.61779 7.40103 9.60321 7.59062C9.58862 7.7802 9.56675 7.97221 9.53758 8.16666ZM9.30425 4.66666H11.0251C10.7431 4.18055 10.3907 3.75763 9.96779 3.39791C9.54487 3.03818 9.06119 2.77082 8.51675 2.59582C8.69175 2.91666 8.84487 3.24964 8.97612 3.59478C9.10737 3.93992 9.21675 4.29721 9.30425 4.66666ZM5.89175 4.66666H8.10842C7.99175 4.23888 7.84105 3.83541 7.65633 3.45624C7.47161 3.07707 7.25286 2.71249 7.00008 2.36249C6.7473 2.71249 6.52855 3.07707 6.34383 3.45624C6.15911 3.83541 6.00842 4.23888 5.89175 4.66666ZM2.97508 4.66666H4.69591C4.78342 4.29721 4.89279 3.93992 5.02404 3.59478C5.15529 3.24964 5.30841 2.91666 5.48342 2.59582C4.93897 2.77082 4.45529 3.03818 4.03237 3.39791C3.60946 3.75763 3.25703 4.18055 2.97508 4.66666Z"
                                fill="#706F6C"
                                stroke="#706F6C"
                                stroke-width="0.3"></path>
                        </svg>
                        FR
                    </a>
                    <a
                        class={`lang-btn text-label-xs ${locale === 'en' ? 'active' : ''}`}
                        data-lang="en"
                        href={enUrl}
                        hreflang="en"
                        lang="en"
                        aria-current={locale === 'en' ? 'page' : undefined}
                    >
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 14 14"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M7.00008 12.8333C6.20286 12.8333 5.44939 12.6802 4.73967 12.3739C4.02994 12.0677 3.41015 11.6496 2.88029 11.1198C2.35043 10.5899 1.93237 9.97013 1.62612 9.26041C1.31987 8.55068 1.16675 7.79721 1.16675 6.99999C1.16675 6.19305 1.31987 5.43714 1.62612 4.73228C1.93237 4.02742 2.35043 3.41006 2.88029 2.8802C3.41015 2.35034 4.02994 1.93228 4.73967 1.62603C5.44939 1.31978 6.20286 1.16666 7.00008 1.16666C7.80703 1.16666 8.56293 1.31978 9.26779 1.62603C9.97265 1.93228 10.59 2.35034 11.1199 2.8802C11.6497 3.41006 12.0678 4.02742 12.374 4.73228C12.6803 5.43714 12.8334 6.19305 12.8334 6.99999C12.8334 7.79721 12.6803 8.55068 12.374 9.26041C12.0678 9.97013 11.6497 10.5899 11.1199 11.1198C10.59 11.6496 9.97265 12.0677 9.26779 12.3739C8.56293 12.6802 7.80703 12.8333 7.00008 12.8333ZM7.00008 11.6375C7.25286 11.2875 7.47161 10.9229 7.65633 10.5437C7.84105 10.1646 7.99175 9.7611 8.10842 9.33332H5.89175C6.00842 9.7611 6.15911 10.1646 6.34383 10.5437C6.52855 10.9229 6.7473 11.2875 7.00008 11.6375ZM5.48342 11.4042C5.30841 11.0833 5.15529 10.7503 5.02404 10.4052C4.89279 10.0601 4.78342 9.70277 4.69591 9.33332H2.97508C3.25703 9.81944 3.60946 10.2424 4.03237 10.6021C4.45529 10.9618 4.93897 11.2292 5.48342 11.4042ZM8.51675 11.4042C9.06119 11.2292 9.54487 10.9618 9.96779 10.6021C10.3907 10.2424 10.7431 9.81944 11.0251 9.33332H9.30425C9.21675 9.70277 9.10737 10.0601 8.97612 10.4052C8.84487 10.7503 8.69175 11.0833 8.51675 11.4042ZM2.47925 8.16666H4.46258C4.43341 7.97221 4.41154 7.7802 4.39696 7.59062C4.38237 7.40103 4.37508 7.20416 4.37508 6.99999C4.37508 6.79582 4.38237 6.59895 4.39696 6.40937C4.41154 6.21978 4.43341 6.02777 4.46258 5.83332H2.47925C2.43064 6.02777 2.39418 6.21978 2.36987 6.40937C2.34557 6.59895 2.33341 6.79582 2.33341 6.99999C2.33341 7.20416 2.34557 7.40103 2.36987 7.59062C2.39418 7.7802 2.43064 7.97221 2.47925 8.16666ZM5.62925 8.16666H8.37092C8.40008 7.97221 8.42196 7.7802 8.43654 7.59062C8.45112 7.40103 8.45842 7.20416 8.45842 6.99999C8.45842 6.79582 8.45112 6.59895 8.43654 6.40937C8.42196 6.21978 8.40008 6.02777 8.37092 5.83332H5.62925C5.60008 6.02777 5.57821 6.21978 5.56362 6.40937C5.54904 6.59895 5.54175 6.79582 5.54175 6.99999C5.54175 7.20416 5.54904 7.40103 5.56362 7.59062C5.57821 7.7802 5.60008 7.97221 5.62925 8.16666ZM9.53758 8.16666H11.5209C11.5695 7.97221 11.606 7.7802 11.6303 7.59062C11.6546 7.40103 11.6667 7.20416 11.6667 6.99999C11.6667 6.79582 11.6546 6.59895 11.6303 6.40937C11.606 6.21978 11.5695 6.02777 11.5209 5.83332H9.53758C9.56675 6.02777 9.58862 6.21978 9.60321 6.40937C9.61779 6.59895 9.62508 6.79582 9.62508 6.99999C9.62508 7.20416 9.61779 7.40103 9.60321 7.59062C9.58862 7.7802 9.56675 7.97221 9.53758 8.16666ZM9.30425 4.66666H11.0251C10.7431 4.18055 10.3907 3.75763 9.96779 3.39791C9.54487 3.03818 9.06119 2.77082 8.51675 2.59582C8.69175 2.91666 8.84487 3.24964 8.97612 3.59478C9.10737 3.93992 9.21675 4.29721 9.30425 4.66666ZM5.89175 4.66666H8.10842C7.99175 4.23888 7.84105 3.83541 7.65633 3.45624C7.47161 3.07707 7.25286 2.71249 7.00008 2.36249C6.7473 2.71249 6.52855 3.07707 6.34383 3.45624C6.15911 3.83541 6.00842 4.23888 5.89175 4.66666ZM2.97508 4.66666H4.69591C4.78342 4.29721 4.89279 3.93992 5.02404 3.59478C5.15529 3.24964 5.30841 2.91666 5.48342 2.59582C4.93897 2.77082 4.45529 3.03818 4.03237 3.39791C3.60946 3.75763 3.25703 4.18055 2.97508 4.66666Z"
                                fill="#706F6C"
                                stroke="#706F6C"
                                stroke-width="0.3"></path>
                        </svg>
                        EN
                    </a>
                </div>

                <Button
                    href={signInUrl}
                    variant="secondary"
                    size="md"
                    data-copy-key={copyKeys.signIn}
                    >{t(copy, copyKeys.signIn, locale, 'SIGN IN')}</Button
                >
                <Button
                    href={requestDemoUrl}
                    variant="primary"
                    size="md"
                    data-copy-key={copyKeys.requestDemo}
                    >{t(copy, copyKeys.requestDemo, locale, 'REQUEST A DEMO')}</Button
                >
            </div>
        </div>
    </div>
</nav>

<style is:global>
    .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 5rem;
        background-color: var(--surface-white);
        border-bottom: var(--stroke-1) solid var(--neutral-grey-4);
        box-shadow: var(--shadow-e1);
        z-index: 1000;
    }

    .navbar-container {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 var(--content-margin-inline);
    }

    .navbar-logo {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-right: var(--space-8);
    }

    .logo-image {
        height: 40px;
        width: auto;
        display: block;
    }

    .navbar-menu {
        display: flex;
        align-items: center;
        gap: var(--space-8);
        flex: 1;
    }

    .navbar-nav {
        display: flex;
        list-style: none;
        gap: 0;
        margin: 0;
        padding: 0;
    }

    .nav-item {
        position: relative;
        display: flex;
        align-items: center;
    }

    .nav-link {
        color: var(--text-primary);
        text-decoration: none;
        padding: var(--space-3) var(--space-5);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
        gap: var(--space-2);
        height: 2.625rem;
        border-radius: var(--radius-s);
        position: relative;
    }

    .nav-link[data-tooltip]::after {
        content: attr(data-tooltip);
        position: absolute;
        left: 50%;
        top: 100%;
        transform: translate(-50%, var(--space-2));
        background: var(--surface-tooltip);
        color: var(--text-white);
        font-size: var(--fs-label-xs);
        line-height: var(--lh-snug);
        padding: 0.375rem var(--space-3);
        border-radius: var(--radius-xs);
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transition:
            opacity 0.2s ease,
            transform 0.2s ease;
        box-shadow: var(--shadow-e2);
        z-index: 20;
    }

    .nav-link[data-tooltip]:hover::after {
        opacity: 1;
        transform: translate(-50%, var(--space-3));
    }

    .nav-link:hover {
        color: var(--text-primary);
        background-color: var(--neutral-grey-4);
    }

    .dropdown-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.3s ease;
    }

    .dropdown-arrow svg {
        width: 1rem;
        height: 1rem;
    }

    .nav-link:hover .dropdown-arrow {
        transform: rotate(180deg);
    }

    .navbar-language {
        display: flex;
        align-items: center;
        gap: 0.125rem;
        padding: 0;
    }

    .lang-btn {
        background: none;
        border: none;
        color: var(--text-secondary);
        cursor: pointer;
        padding: var(--space-1);
        transition: color 0.3s ease;
        display: flex;
        align-items: center;
        gap: var(--space-1);
    }

    .lang-btn svg {
        width: 0.875rem;
        height: 0.875rem;
    }

    .lang-btn:hover,
    .lang-btn.active {
        color: var(--text-primary);
    }

    .lang-btn.active svg path {
        stroke: var(--text-primary);
        fill: var(--text-primary);
    }

    .lang-divider {
        color: var(--neutral-grey-3);
        margin: 0 var(--space-1);
        display: none;
    }

    .navbar-actions {
        display: flex;
        gap: var(--space-4);
        align-items: center;
        margin-left: auto;
        flex-shrink: 0;
    }

    .hamburger {
        display: none;
        flex-direction: column;
        cursor: pointer;
        gap: 0.375rem;
        margin-right: var(--space-6);
    }

    .hamburger span {
        width: var(--space-6);
        height: 0.1875rem;
        background-color: var(--text-primary);
        border-radius: var(--stroke-2);
        transition: all 0.3s ease;
    }

    .hamburger.active span:nth-child(1) {
        transform: rotate(45deg) translate(0.5rem, 0.5rem);
    }

    .hamburger.active span:nth-child(2) {
        opacity: 0;
    }

    .hamburger.active span:nth-child(3) {
        transform: rotate(-45deg) translate(0.4375rem, -0.4375rem);
    }

    @media (min-width: 1024px) and (max-width: 1200px) {
        .navbar-container {
            padding: 0 var(--content-margin-inline);
        }

        .navbar-logo {
            margin-right: var(--space-6);
        }

        .navbar-nav {
            gap: 0;
        }

        .nav-link {
            padding: var(--space-2) var(--space-3);
            width: auto;
            height: 2.375rem;
        }

        .navbar-language {
            padding: 0 var(--space-2);
        }

        .navbar-actions {
            gap: var(--space-2);
        }

        .navbar-actions .btn {
            padding: var(--space-2) var(--space-3);
        }
    }

    @media (max-width: 1023px) {
        .navbar {
            height: 4.375rem;
        }

        .navbar-container {
            padding: 0 var(--content-margin-inline);
        }

        .navbar-logo {
            margin-right: auto;
        }

        .hamburger {
            display: flex;
        }

        .navbar-menu {
            position: absolute;
            top: 4.375rem;
            left: 0;
            right: 0;
            background-color: var(--surface-white);
            flex-direction: column;
            gap: 0;
            border-bottom: var(--stroke-1) solid var(--neutral-grey-4);
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }

        .navbar-menu.active {
            max-height: 600px;
        }

        .navbar-nav {
            flex-direction: column;
            width: 100%;
            gap: 0;
        }

        .nav-item {
            width: 100%;
            padding: var(--space-4) var(--content-margin-inline);
            border-bottom: var(--stroke-1) solid var(--neutral-grey-4);
        }

        .nav-link {
            padding: 0;
        }

        .dropdown-arrow {
            margin-left: auto;
            margin-right: 0;
        }

        .navbar-language {
            border: none;
            padding: var(--space-4) var(--content-margin-inline);
            justify-content: center;
            border-bottom: var(--stroke-1) solid var(--neutral-grey-4);
            width: 100%;
        }

        .navbar-actions {
            flex-direction: column;
            width: 100%;
            padding: var(--space-4) var(--content-margin-inline);
            gap: var(--space-2);
            margin-left: 0;
        }

        .navbar-actions .btn {
            width: 100%;
            text-align: center;
            padding: var(--space-3) var(--space-4);
        }

        body {
            padding-top: 4.375rem;
        }
    }

    @media (max-width: 767px) {
        .navbar-container {
            padding: 0 var(--content-margin-inline);
        }

        .navbar-logo {
            margin-right: auto;
        }

        .navbar-menu.active {
            max-height: 500px;
        }
    }
</style>
