---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Redirecting to MTM" description="Redirecting to the MTM homepage." locale="en" noindex={true}>
    <Fragment slot="head">
        <meta http-equiv="refresh" content={`0;url=${base}en/`} />
    </Fragment>

        <main class="content-boundary redirect-main">
        <a href={`${base}en/`}>Go to English site</a>
    </main>
</Layout>

<style>
    .redirect-main {
        padding-top: calc(var(--navbar-height) + 32px);
    }
</style>
